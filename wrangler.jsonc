{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "help-desk",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-02",
  "keep_vars": true,
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "BRIDGE_DB",
      "database_name": "help-desk",
      "database_id": "7dc29f69-8c4f-407e-acd7-fe8dce7619b1",
      "migrations_dir": "migrations"
    }
  ],
  "triggers": {
    "crons": ["0 * * * *"]
  }
}
