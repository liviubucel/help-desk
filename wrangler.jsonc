{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "help-desk-bridge",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-02",
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "BRIDGE_DB",
      "database_name": "helpdesk_bridge",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID",
      "migrations_dir": "migrations"
    }
  ]
}
